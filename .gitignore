# ============================================================
# Root .gitignore — TRAINET
# DO NOT COMMIT API KEYS — USE ENV VARIABLES ONLY
# ============================================================

# Environment variables — NEVER commit these
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# Python virtual environment
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.pkl
models/

# Node dependencies
node_modules/

# Build output
dist/
build/
.next/

# Logs
logs/
*.log
npm-debug.log*

# Uploads (user-generated content)
backend/uploads/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Coverage
coverage/
.nyc_output/

# Kiro IDE metadata
.kiro/

# TypeScript build info
*.tsbuildinfo

# Next.js
out/

# Vercel
.vercel

# Backend ad-hoc debug scripts (not part of runtime)
backend/test-*.js
backend/check-*.js
backend/create-*.js
backend/demo-*.js
backend/run-migration.js
backend/test-*.sh
