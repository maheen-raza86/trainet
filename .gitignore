# ============================================================
# Root .gitignore — TRAINET
# DO NOT COMMIT API KEYS — USE ENV VARIABLES ONLY
# ============================================================

# Environment variables — NEVER commit these
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# Python virtual environment
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.pkl
models/

# Node dependencies
node_modules/

# Build output
dist/
build/
.next/

# Logs
logs/
*.log
npm-debug.log*

# Uploads (user-generated content)
backend/uploads/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Coverage
coverage/
.nyc_output/
